# Copy to .env.production on the VPS. Keep that file out of Git and chmod 600.
# Generate all *_PASSWORD and *_SECRET values with: openssl rand -hex 32

POSTGRES_SUPERUSER_PASSWORD=replace_with_64_hex_characters
APP_DB_NAME=titop_arenda
APP_DB_USER=titop_arenda
APP_DB_PASSWORD=replace_with_64_hex_characters
GLITCHTIP_DB_NAME=titop_glitchtip
GLITCHTIP_DB_USER=titop_glitchtip
GLITCHTIP_DB_PASSWORD=replace_with_64_hex_characters
GLITCHTIP_SECRET_KEY=replace_with_64_hex_characters

# Vision moderation is synchronous for avatars/chat and may take up to 45s.
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=75s
# Server-side DSN from the titop-arenda-api project in GlitchTip.
GLITCHTIP_BACKEND_DSN=
# Generic GlitchTip webhook -> Telegram bridge. Generate the webhook secret
# with `openssl rand -hex 32`; configure all three values together.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
GLITCHTIP_TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_TIMEOUT=10s
# URL-encode the username/password. Yandex SSL example:
# smtp+ssl://notifications%40titop.ru:URL_ENCODED_APP_PASSWORD@smtp.yandex.ru:465
GLITCHTIP_EMAIL_URL=
GLITCHTIP_DEFAULT_FROM_EMAIL=notifications@titop.ru

# Titop Arenda public endpoints.
PUBLIC_API_BASE_URL=https://arenda.titop.ru
# Public bucket base. Either use a dedicated public/CDN domain, or set this to
# S3_ENDPOINT: in path-style mode the API adds S3_PUBLIC_BUCKET automatically.
MEDIA_BASE_URL=https://replace-with-public-s3-domain
APP_ENV=production
# Set to the deployed Git commit SHA (for example: f3761d1).
APP_RELEASE=
JWT_SECRET=replace_with_64_hex_characters
EMAIL_UNSUBSCRIBE_SECRET=replace_with_64_hex_characters
AUTH_EXPOSE_CODE=false
TRUST_PROXY_HEADERS=true

# SMTP for login codes and notifications.
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
EMAIL_DAILY_LIMIT=500
ADMIN_EMAIL=

# Phone verification.
UCALLER_ENABLED=false
UCALLER_API_URL=https://api.ucaller.ru
UCALLER_API_KEY=
UCALLER_SERVICE_ID=
UCALLER_TIMEOUT=10s

# Payments remain mock until production YooKassa credentials are ready.
PAYMENT_PROVIDER=mock
PAYMENT_API_URL=https://api.yookassa.ru/v3
PAYMENT_SHOP_ID=
PAYMENT_SECRET=
# Must match the mobile Expo scheme.
PAYMENT_RETURN_URL=titop-arenda://payments/return
PAYMENT_CAPTURE=true
PAYMENT_PROVIDER_TIMEOUT=15s
PAYMENT_ADMIN_TOKEN=
PAYMENT_ADMIN_TOKEN_PREVIOUS=

# LLM and location enrichment.
LLM_BASE_URL=
LLM_API_KEY=
LLM_GENERATION_MODEL=
LLM_MODERATION_MODEL=
LLM_REVIEW_MODERATION_MODEL=
LLM_IMAGE_MODERATION_MODEL=moonshotai/Kimi-K2.6
LLM_TIMEOUT=15s
DADATA_API_KEY=
OVERPASS_URL=https://overpass-api.de/api/interpreter
OVERPASS_TIMEOUT=12s

# Centrifugo server-to-server credentials.
CENTRIFUGO_HMAC_SECRET=replace_with_64_hex_characters
CENTRIFUGO_API_KEY=replace_with_64_hex_characters

# Existing S3-compatible object storage. Do not run MinIO on this VPS.
S3_ENDPOINT=
S3_PRESIGN_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_PUBLIC_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_USE_PATH_STYLE=true
