# Base URL of the Go backend REST API (see backend/).
# EXPO_PUBLIC_* vars are inlined into the client bundle at build time.
#
#   - Android emulator:        http://10.0.2.2:8080
#   - iOS simulator / web:     http://localhost:8080
#   - Physical device on LAN:  http://<your-machine-ip>:8080
EXPO_PUBLIC_API_URL=http://localhost:8080

# WebSocket URL of the Centrifugo real-time server.
EXPO_PUBLIC_WS_URL=ws://localhost:8000/connection/websocket

# Public DSN from the titop-arenda-mobile project in GlitchTip. It is safe to
# include in the mobile bundle; it only authorizes sending error events.
EXPO_PUBLIC_GLITCHTIP_DSN=

# Build-only GlitchTip/Sentry CLI settings used to upload release source maps.
# Keep SENTRY_AUTH_TOKEN in EAS/CI secrets, never prefix it with EXPO_PUBLIC.
SENTRY_URL=https://errors.titop.ru
SENTRY_ORG=
SENTRY_PROJECT=titop-arenda-mobile
SENTRY_AUTH_TOKEN=

# Yandex MapKit API key (https://developer.tech.yandex.ru/).
# NOTE: EXPO_PUBLIC_* values are inlined into the client bundle — treat this
# key as public and restrict it by bundle ID / API scope in the Yandex console.
EXPO_PUBLIC_YANDEX_MAPKIT_API_KEY=
