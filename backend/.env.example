# Copy to .env for local development (loaded automatically via godotenv).

# HTTP listen address.
HTTP_ADDR=:8080

# PostgreSQL connection string (pgx). Matches docker-compose.yml defaults.
DATABASE_URL=postgres://sutki:sutki@localhost:5432/sutki?sslmode=disable

# Password for the dockerized Postgres (docker-compose.yml). Defaults to the
# dev value "sutki" — set a strong value in production and update DATABASE_URL
# to match. The container port is bound to 127.0.0.1 only.
POSTGRES_PASSWORD=

# Base URL used to turn stored relative media paths into absolute URLs.
# Leave empty to return raw stored paths. In production this points at the
# Timeweb S3 bucket / CDN.
MEDIA_BASE_URL=

# JWT signing secret for the auth endpoints. If empty, a random ephemeral
# secret is generated on startup (dev only — tokens become invalid on restart).
# Set a stable secret in production.
JWT_SECRET=

# Access / refresh token lifetimes (Go duration syntax).
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

# Dev only: when true, POST /auth/email/request returns the login code in the
# response (and logs it) so you can sign in without an SMTP provider.
# Defaults to false (secure by default); this file enables it for local dev.
# Never set to true in production.
AUTH_EXPOSE_CODE=true

# SMTP Mailer settings (for passwordless email-code verification).
# Used to send verification emails via Yandex SMTP.
# If SMTP_USERNAME/SMTP_PASSWORD are left empty, no emails are sent and codes
# are only logged (if AUTH_EXPOSE_CODE=true).
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# Nearby infrastructure for listing location summaries (Overpass / OSM).
OVERPASS_URL=https://overpass-api.de/api/interpreter
OVERPASS_TIMEOUT=12s

# Phone authentication. uCaller handles primary Flash Call and voice fallback.
UCALLER_ENABLED=false
UCALLER_API_URL=https://api.ucaller.ru
UCALLER_API_KEY=
UCALLER_SERVICE_ID=
UCALLER_TIMEOUT=10s

# Payment platform. Use mock for local/security tests. YooKassa sandbox and
# production use the same code path; only shop credentials change.
PAYMENT_PROVIDER=mock
PAYMENT_API_URL=https://api.yookassa.ru/v3
PAYMENT_SHOP_ID=
PAYMENT_SECRET=
PAYMENT_RETURN_URL=sutki://payments/return
PAYMENT_CAPTURE=true
PAYMENT_PROVIDER_TIMEOUT=15s
# Interim protection for money-moving admin endpoints. Rotate by moving the old
# value to *_PREVIOUS, installing a new active token, then clearing PREVIOUS
# after clients are updated. Replace this with authenticated RBAC before prod.
# Values are never logged. Keep both empty to disable admin endpoints.
PAYMENT_ADMIN_TOKEN=
PAYMENT_ADMIN_TOKEN_PREVIOUS=

# LLM (OpenAI-compatible) API Config
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-3.5-turbo
LLM_GENERATION_MODEL=gpt-3.5-turbo
LLM_MODERATION_MODEL=gpt-3.5-turbo
LLM_REVIEW_MODERATION_MODEL=gpt-3.5-turbo
LLM_TIMEOUT=15s

# Centrifugo realtime server.
CENTRIFUGO_URL=http://127.0.0.1:8000
# REQUIRED. Shared HMAC secret used to sign connection/subscription JWTs. Must
# match Centrifugo's CENTRIFUGO_CLIENT_TOKEN_HMAC_SECRET_KEY. The backend refuses
# to start if this is empty or a known placeholder. Generate one with:
#   openssl rand -hex 32
CENTRIFUGO_HMAC_SECRET=
# API key for server-to-server publish calls. Must match Centrifugo's
# CENTRIFUGO_HTTP_API_KEY. Generate with: openssl rand -hex 32
CENTRIFUGO_API_KEY=

# Set to true ONLY when the backend runs behind a trusted reverse proxy
# (nginx, ALB, ...) that overwrites/appends X-Forwarded-For. When false
# (default), proxy headers are ignored and the TCP peer address is used, so
# clients cannot spoof their IP to bypass per-IP rate limits or poison
# session geo data.
TRUST_PROXY_HEADERS=false


