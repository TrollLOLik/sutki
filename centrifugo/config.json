{
  "http_api": {
    "key": "dev_api_key"
  },
  "client": {
    "allowed_origins": [
      "*"
    ],
    "token": {
      "hmac_secret_key": "YOUR_SHARED_HMAC_SECRET_KEY"
    },
    "subscribe_to_user_personal_channel": {
      "enabled": true,
      "personal_channel_namespace": "user"
    }
  },
  "channel": {
    "namespaces": [
      {
        "name": "chat",
        "presence": true
      },
      {
        "name": "user",
        "allow_user_limited_channels": true
      }
    ]
  }
}
